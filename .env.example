# ── SizhuAtelier server env ── copy to .env for local dev; set these in Railway for prod ──

# Stripe (TEST keys while developing — start with sk_test_… / pk_test_…)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public origin for Stripe success/cancel redirects.
# On Railway this auto-falls back to RAILWAY_PUBLIC_DOMAIN; set explicitly to be safe.
PUBLIC_URL=https://sizhuatelier-shop-production.up.railway.app

# Currency for Stripe line items (ISO 4217, lowercase)
CURRENCY=eur

# ── Optional: order persistence (Railway Postgres plugin sets DATABASE_URL) ──
# DATABASE_URL=postgresql://user:pass@host:5432/db

# ── Optional: confirmation emails via Resend (https://resend.com) ──
# RESEND_API_KEY=re_xxx
# ORDER_FROM_EMAIL=SizhuAtelier <orders@yourdomain>
# ORDER_NOTIFY_EMAIL=atelier@yourdomain   # where new-order notices go
